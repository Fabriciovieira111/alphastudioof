<!DOCTYPE html>
<html lang="pt-br">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Alpha Studio OFC - Agência Digital</title>
<meta name="description" content="Alpha Studio OFC - Transformamos negócios em máquinas de vendas com marketing digital e automação.">
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;800&display=swap" rel="stylesheet">
<script src="https://unpkg.com/scrollreveal"></script>
<style>
*{margin:0;padding:0;box-sizing:border-box;font-family:'Poppins',sans-serif}
body{background:#0b0b15;color:#fff;overflow-x:hidden}
#loader{position:fixed;width:100%;height:100vh;background:#0b0b15;display:flex;align-items:center;justify-content:center;z-index:9999}
.loader-circle{width:60px;height:60px;border:6px solid #222;border-top:6px solid #6C5CE7;border-radius:50%;animation:spin 1s linear infinite}
@keyframes spin{100%{transform:rotate(360deg)}}
header{position:fixed;width:100%;top:0;padding:20px 8%;display:flex;justify-content:space-between;align-items:center;background:rgba(0,0,0,0.6);backdrop-filter:blur(15px);z-index:1000}
header h1{font-weight:800;background:linear-gradient(90deg,#6C5CE7,#00cec9);-webkit-background-clip:text;color:transparent}
nav a{color:#fff;margin-left:25px;text-decoration:none;position:relative}
nav a::after{content:'';position:absolute;width:0;height:2px;background:#00cec9;left:0;bottom:-5px;transition:0.4s}
nav a:hover::after{width:100%}
section{padding:120px 8%}
.hero{height:100vh;display:flex;flex-direction:column;justify-content:center;align-items:center;text-align:center;background:linear-gradient(270deg,#0b0b15,#1a1a2e,#0b0b15);background-size:600% 600%;animation:bgMove 12s ease infinite}
@keyframes bgMove{0%{background-position:0% 50%}50%{background-position:100% 50%}100%{background-position:0% 50%}}
.hero h2{font-size:52px;font-weight:800;background:linear-gradient(90deg,#6C5CE7,#00cec9);-webkit-background-clip:text;color:transparent}
.hero p{margin-top:20px;color:#ccc}
.btn{margin-top:35px;padding:15px 40px;border:none;border-radius:50px;font-weight:600;background:#6C5CE7;color:#fff;cursor:pointer;position:relative;overflow:hidden}
.btn::before{content:'';position:absolute;top:0;left:-100%;width:100%;height:100%;background:linear-gradient(90deg,transparent,rgba(255,255,255,0.4),transparent);transition:0.5s}
.btn:hover::before{left:100%}
.btn:hover{box-shadow:0 0 20px #6C5CE7}
.cards{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:30px;margin-top:50px}
.card{background:rgba(255,255,255,0.05);backdrop-filter:blur(15px);border-radius:20px;padding:35px;transition:0.4s;border:1px solid rgba(255,255,255,0.1)}
.card:hover{transform:translateY(-10px);box-shadow:0 0 25px rgba(108,92,231,0.5)}
.stats{display:flex;flex-wrap:wrap;justify-content:space-around;margin-top:60px;text-align:center}
.stat h3{font-size:42px;color:#00cec9}
form{max-width:600px;margin:auto;margin-top:40px;display:flex;flex-direction:column;gap:15px}
input,textarea{padding:15px;border-radius:12px;border:none;background:#1a1a2e;color:#fff}
textarea{resize:none;height:120px}
footer{text-align:center;padding:40px;background:#0a0a12;color:#888}
.whatsapp{position:fixed;bottom:20px;right:20px;background:#25D366;color:white;padding:15px 20px;border-radius:50px;text-decoration:none;font-weight:600;box-shadow:0 0 15px #25D366}
.pix-box{margin-top:30px;text-align:center}
.pix-box p{margin-bottom:10px;color:#ccc}
@media(max-width:768px){.hero h2{font-size:34px}}
</style>
</head>
<body>
<div id="loader"><div class="loader-circle"></div></div>
<header>
<h1>Alpha Studio OFC</h1>
<nav>
<a href="#servicos">Serviços</a>
<a href="#resultados">Resultados</a>
<a href="#contato">Contato</a>
</nav>
</header>
<section class="hero">
<h2>Transformamos Negócios em Máquinas de Vendas</h2>
<p>Marketing Digital • Automação • Alta Conversão</p>
<a href="#contato"><button class="btn">Quero Crescer Agora</button></a>
</section>
<section id="servicos">
<h2>Serviços Estratégicos</h2>
<div class="cards">
<div class="card">Sites de Alta Conversão</div>
<div class="card">Funis Automatizados</div>
<div class="card">Gestão de Tráfego Pago</div>
<div class="card">Automação WhatsApp</div>
</div>
</section>
<section id="resultados">
<h2>Resultados Reais</h2>
<div class="stats">
<div class="stat"><h3 id="clientes">0</h3><p>Clientes</p></div>
<div class="stat"><h3 id="projetos">0</h3><p>Projetos</p></div>
<div class="stat"><h3 id="vendas">0</h3><p>Vendas Geradas</p></div>
</div>
</section>
<section id="contato">
<h2>Entre em Contato</h2>
<form action="https://formsubmit.co/seuemail@gmail.com" method="POST">
<input type="text" name="nome" placeholder="Seu Nome" required>
<input type="email" name="email" placeholder="Seu Email" required>
<textarea name="mensagem" placeholder="Fale sobre seu projeto"></textarea>
<button class="btn" type="submit">Enviar Mensagem</button>
</form>
<div class="pix-box">
<p>Pagamento via Pix:</p>
<strong>11 980112081</strong>
</div>
</section>
<a class="whatsapp" href="https://wa.me/5511961635903" target="_blank">WhatsApp</a>
<footer>
<p>© 2026 Alpha Studio OFC - Todos os direitos reservados</p>
<p>Domínio sugerido: www.alphastudioofc.com</p>
</footer>
<script>
window.addEventListener('load',()=>{document.getElementById('loader').style.display='none'})
ScrollReveal().reveal('.card',{delay:200,distance:'40px',origin:'bottom',interval:200});
ScrollReveal().reveal('.stat',{delay:200,distance:'40px',origin:'top',interval:200});
function animateValue(id,start,end,duration){let obj=document.getElementById(id);let range=end-start;let current=start;let increment=end>start?1:-1;let stepTime=Math.abs(Math.floor(duration/range));let timer=setInterval(function(){current+=increment;obj.textContent=current;if(current==end){clearInterval(timer)}},stepTime);} 
animateValue("clientes",0,150,2000);
animateValue("projetos",0,420,2000);
animateValue("vendas",0,980,2000);
</script>
</body>
</html>
